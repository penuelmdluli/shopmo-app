{
  "name": "shopmo-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://shopmoo.co.za",
    "NEXT_PUBLIC_BASE_URL": "https://shopmoo.co.za",
    "NEXT_PUBLIC_APP_NAME": "ShopMO",
    "NEXT_PUBLIC_SUPABASE_URL": "https://gyrbzrmtztkexnbzxebx.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd5cmJ6cm10enRrZXhuYnp4ZWJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIzOTAzOTIsImV4cCI6MjA4Nzk2NjM5Mn0.YI3PhWV8l3ry7JKb-wwL0VQ8VJ4jQvNl3yfvgSeMgqI",
    "SHOPMO_WAREHOUSE_ADDRESS": "Pretoria Central",
    "SHOPMO_WAREHOUSE_CITY": "Pretoria",
    "SHOPMO_WAREHOUSE_PROVINCE": "Gauteng",
    "SHOPMO_WAREHOUSE_POSTAL": "0001",
    "OWNER_EMAIL": "mdlulipenuel@gmail.com"
  },
  // Secrets to set via: npx wrangler secret put <NAME>
  // Required: SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, COURIER_GUY_API_KEY
  // Required for payments: YOCO_SECRET_KEY, YOCO_WEBHOOK_SECRET
  // Required for email: RESEND_API_KEY
  // Optional: HUNTER_API_KEY

  // Custom domain routes
  "routes": [
    { "pattern": "shopmoo.co.za", "custom_domain": true },
    { "pattern": "www.shopmoo.co.za", "custom_domain": true }
  ]
}
