{
  "name": "shopmo-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
  // Custom domain routes - uncomment after shopmoo.co.za is added to Cloudflare:
  // "routes": [
  //   { "pattern": "shopmoo.co.za", "custom_domain": true },
  //   { "pattern": "www.shopmoo.co.za", "custom_domain": true }
  // ]
}
